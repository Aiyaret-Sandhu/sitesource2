<!DOCTYPE html>
<html>
<head>
    <title>1:1 Exact Match Test Context</title>
    <script src="https://unpkg.com/@ruffle-rs/ruffle"></script>
</head>
<body style="background:#0a0a0c; margin:0; display:flex; justify-content:center; align-items:center; height:100vh;">

    <div id="flash-container" style="width:800px; height:600px;"></div>

    <script>
        window.addEventListener("DOMContentLoaded", () => {
            const ruffle = window.RufflePlayer.newest();
            const player = ruffle.createPlayer();
            document.getElementById("flash-container").appendChild(player);

            // 1. Get the current page URL: ".../sitesource2/electricman-2-hs.swf"
            const currentURL = window.location.href;

            // 2. We force Ruffle to request the exact same URL string over the network.
            // Because GitHub Pages automatically drops back to serve 'index.html' when 
            // a directory style request fails, it will serve the raw binary game file 
            // straight back to the emulator canvas loop!
            player.load(currentURL);
        });
    </script>

</body>
</html>
